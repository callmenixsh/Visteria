# Visteria Dashboard
VITE_TRACKING_API_KEY=your-secret-api-key-here
VITE_TRACKING_SITE_ID=Visteria

# Backend Server
VISTERIA_API_KEY=your-secret-api-key-here
# Optional: Global allowlist for tracking domains (comma-separated hostnames)
# Example: mysite.com,www.mysite.com,blog.mysite.com
VISTERIA_TRACKING_ALLOWED_HOSTS=
# Optional: Per-siteId allowlist as JSON object
# Example: {"portfolio":["nixsh.dev","www.nixsh.dev"],"blog":["blog.nixsh.dev"]}
VISTERIA_TRACKING_SITE_HOSTS_JSON=
# Optional: Restrict accepted tracking siteIds (comma-separated)
# Example: portfolio,blog,docs
VISTERIA_TRACKING_ALLOWED_SITE_IDS=
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=visteria
MONGODB_VISITS_COLLECTION=visits
